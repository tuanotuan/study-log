DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-a-long-random-secret"
UPLOAD_DIR="./public/uploads"
APP_URL="http://localhost:3000"
AUTH_CODE_DEBUG="true"

# Optional. If omitted, verification/reset codes are printed in server logs.
# Gmail example: SMTP_USER is your Gmail address, SMTP_PASS is a Gmail App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"
